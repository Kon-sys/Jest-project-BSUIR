  "item": [
    {
      "name": "status",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Response time < 200ms\", () => pm.expect(pm.response.responseTime).to.be.below(200));",
              "",
              "pm.test(\"Schema: status + timestamp\", () => {",
              "  pm.expect(json).to.have.property(\"status\");",
              "  pm.expect(json).to.have.property(\"timestamp\");",
              "  pm.expect(json.status).to.eql(\"online\");",
              "});",
              "",
              "pm.environment.set(\"last_check\", json.status);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/status",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "status"
          ]
        }
      }
    },
