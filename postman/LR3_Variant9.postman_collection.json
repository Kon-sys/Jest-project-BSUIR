{
  "info": {
    "_postman_id": "d3a4c4c3-3d1a-4a2e-9caa-0a2f3f3f3f3f",
    "name": "LR3 Variant 9",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/status",
          "host": ["{{base_url}}"],
          "path": ["api", "status"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Response time < 200ms\", () => pm.expect(pm.response.responseTime).to.be.below(200));",
              "",
              "pm.test(\"Schema: status + timestamp\", () => {",
              "  pm.expect(json).to.have.property(\"status\");",
              "  pm.expect(json).to.have.property(\"timestamp\");",
              "  pm.expect(json.status).to.eql(\"online\");",
              "});",
              "",
              "pm.environment.set(\"last_check\", json.status);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "check-login",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/auth/check-login?name={{login}}",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "check-login"],
          "query": [
            { "key": "name", "value": "{{login}}" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Response time < 200ms\", () => pm.expect(pm.response.responseTime).to.be.below(200));",
              "",
              "pm.test(\"Schema\", () => {",
              "  pm.expect(json).to.have.all.keys(\"status\", \"login\", \"available\");",
              "  pm.expect(json.status).to.eql(\"success\");",
              "  pm.expect(json.login).to.be.a(\"string\");",
              "  pm.expect(json.available).to.be.a(\"boolean\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
